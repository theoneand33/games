---
const Game = "Super Mario 63";
import Layout from "../../layout/layout.astro";
import Flash from "../../components/flash.astro";
const gamePath = "/flash/super-mario-63.swf";
---

<Layout Game={Game}>
  <div style="text-align: center">
    <div
      id="container"
      style="border: #ccc 0px solid; height: 100%; width: 100%"
    >
    </div>
    <Flash gamePath={gamePath} />
  </div>

  
</Layout>