---
const Game = "Achievement Unlocked";
import Layout from "../../layout/layout.astro";
import Flash from "../../components/flash.astro";
const gamePath = "/flash/achievementunlocked.swf";
---

<Layout Game={Game}>
  <div style="text-align: center">
    <div
      id="container"
      style="border: #ccc 0px solid; height: 100%; width: 100%"
    >
    </div>
    <script src="/ruffle/ruffle.js" is:inline></script>
    <Flash gamePath={gamePath} />
  </div>
</Layout>
