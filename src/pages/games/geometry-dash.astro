---

const Game = "Geometry Dash";
import Layout from "../../layout/layout.astro";
---

<!doctype html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta
    name="description"
    content="Play Geometry Dash unblocked online. - unblocked and ready to play!"
  />
  <title>{Game}</title>
  <script defer src="/_vercel/insights/script.js"></script>
  <style>
    body {
      margin: 0;
      overflow: hidden;
    }
    iframe {
      width: 98vw;
      height: 96vh;
      border: none;
    }
  </style>
</head>
<Layout>
  <div style="text-align: center">
    <iframe
      src="https://scratch.mit.edu/projects/105500895/embed"
      frameborder="0"
      scrolling="no"
      allowfullscreen="allowfullscreen"></iframe>
  </div>

  <script type="text/javascript">
    atOptions = {
      key: "1cc5f63f55fc28b4c469b5e4e2f1a79d",
      format: "iframe",
      height: 250,
      width: 300,
      params: {},
    };
  </script>
  <script
    type="text/javascript"
    src="//www.highperformanceformat.com/1cc5f63f55fc28b4c469b5e4e2f1a79d/invoke.js"
  ></script>
</Layout>
