---
import Layout from "../layout/layout.astro";
import Gametile from "../components/gametile.astro";
import { getGameSEO } from "../data/game-seo";
import { slugToGame } from "../data/game-slugs";

const pageTitle =
  "Superfun Games - Unblocked Games for School Chromebook | No Flash Required (2026)";

// ponytail: derive Path/Image from data layer instead of duplicating
const gameToSlug: Record<string, string> = {};
for (const [slug, name] of Object.entries(slugToGame)) {
  gameToSlug[name] = slug;
}
gameToSlug["Run 3"] = "run-3";

// ponytail: ordered by popularity — series grouped contiguously
const games = [
  "Happy Wheels",
  "Plants vs Zombies",
  "Run 3",
  "Fireboy and Watergirl",
  "Bloons TD 5",
  "Super Mario 63",
  "Tetris",
  "Pac-Man",
  "Run 2",
  "Fancy Pants Adventure",
  "Stick War",
  "Age of War",
  "Madness: Project Nexus",
  "Strike Force Heroes",
  "The World's Hardest Game",
  "Vex 3",
  "Gun Mayhem 2",
  "Bubble Trouble",
  "QWOP",
  "Crush the Castle",
  "Burrito Bison",
  "Boxhead 2Play",
  "The Impossible Quiz 2",
  "Interactive Buddy",
  "Achievement Unlocked",
  "Ultimate Flash Sonic",
  "Doom",
  "Minesweeper",
  "Geography Game USA",
  "Henry Stickmin 1: Breaking the Bank",
  "Henry Stickmin 2: Escaping the Prison",
  "Henry Stickmin 3: Stealing the Diamond",
  "Henry Stickmin 4: Infiltrating the Airship",
  "Henry Stickmin 5: Fleeing the Complex",
  "Duck Life 1",
  "Duck Life 2",
  "Duck Life 3",
  "Duck Life 4",
  "Duck Life 5",
  "Learn to Fly 2",
  "Learn to Fly 3",
  "Super Mario Flash 1",
  "Super Mario Flash 2",
  "Swords and Sandals 1",
  "Swords and Sandals 2",
  "Riddle School 2",
  "Riddle School 3",
  "Riddle School 4",
  "Riddle School 5",
  "Hobo 1: Brawl",
  "Hobo 2",
  "Hobo 3: Wanted",
  "Hobo 4: Total War",
  "Hobo 5: Space Brawls",
  "Hobo 6: Hell",
  "Hobo 7",
  "Hobo vs Zombies",
];
---

<Layout pageTitle={pageTitle} isHome={true}>
  <h1 data-pagefind-body class="text-2xl font-bold mb-2 m-5">
    Play Unblocked Games on Your School Chromebook - Working 2026
  </h1>
  <p class="text-sm text-gray-600 mb-4 m-5">
    Play classic Flash games and browser games on your school Chromebook without
    needing any plugins or downloads. All games run directly in your Chrome
    browser via Ruffle emulation - no Flash Player required. Relive your
    favorite nostalgic games like <a
      href="/games/happy-wheels"
      class="text-blue-600 hover:underline">Happy Wheels</a
    >, <a href="/games/plants-vs-zombies" class="text-blue-600 hover:underline"
      >Plants vs Zombies</a
    >, <a
      href="/games/strike-force-heroes"
      class="text-blue-600 hover:underline">Strike Force Heroes</a
    >, and more. Updated and working in 2026.
  </p>

  <div class="flex flex-wrap gap-2 m-5 mb-4 text-sm">
    <span class="font-semibold text-gray-700">Popular:</span>
    <a href="/games/happy-wheels" class="text-blue-600 hover:underline"
      >Happy Wheels</a
    >
    <a href="/games/plants-vs-zombies" class="text-blue-600 hover:underline"
      >Plants vs Zombies</a
    >
    <a href="/games/run-3" class="text-blue-600 hover:underline">Run 3</a>
    <a href="/games/fireboy-and-watergirl" class="text-blue-600 hover:underline"
      >Fireboy and Watergirl</a
    >
    <a href="/games/bloons-td-5" class="text-blue-600 hover:underline"
      >Bloons TD 5</a
    >
    <a href="/games/super-mario-63" class="text-blue-600 hover:underline"
      >Super Mario 63</a
    >
    <a href="/games/strike-force-heroes" class="text-blue-600 hover:underline"
      >Strike Force Heroes</a
    >
    <a href="/games/madness-project-nexus" class="text-blue-600 hover:underline"
      >Madness: Project Nexus</a
    >
    <a href="/games/gun-mayhem-2" class="text-blue-600 hover:underline"
      >Gun Mayhem 2</a
    >
  </div>

  <div class="games-grid">
    {games.map((name, i) => {
      const seo = getGameSEO(name);
      return <Gametile Game={name} Path={"/games/" + gameToSlug[name]} Image={seo?.image || "/images/games_logo_light.svg"} priority={i === 0} />;
    })}
  </div>
</Layout>
