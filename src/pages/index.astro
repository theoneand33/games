---

<Layout pageTitle={pageTitle} isHome={true}>
  <h1 data-pagefind-body class="text-2xl font-bold mb-2 m-5">
    Play Unblocked Games on Your School Chromebook - Working 2026
  </h1>
  <p class="text-sm text-gray-600 mb-4 m-5">
    Play classic Flash games and browser games on your school Chromebook without
    needing any plugins or downloads. All games run directly in your Chrome
    browser via Ruffle emulation - no Flash Player required. Relive your
    favorite nostalgic games like <a
      href="/games/happy-wheels"
      class="text-blue-600 hover:underline">Happy Wheels</a
    >, <a href="/games/plants-vs-zombies" class="text-blue-600 hover:underline"
      >Plants vs Zombies</a
    >, <a
      href="/games/strike-force-heroes"
      class="text-blue-600 hover:underline">Strike Force Heroes</a
    >, and more. Updated and working in 2026.
  </p>

  <div class="flex flex-wrap gap-2 m-5 mb-4 text-sm">
    <span class="font-semibold text-gray-700">Popular:</span>
    <a href="/games/happy-wheels" class="text-blue-600 hover:underline"
      >Happy Wheels</a
    >
    <a href="/games/plants-vs-zombies" class="text-blue-600 hover:underline"
      >Plants vs Zombies</a
    >
    <a href="/games/run-3" class="text-blue-600 hover:underline">Run 3</a>
    <a href="/games/fireboy-and-watergirl" class="text-blue-600 hover:underline"
      >Fireboy and Watergirl</a
    >
    <a href="/games/bloons-td-5" class="text-blue-600 hover:underline"
      >Bloons TD 5</a
    >
    <a href="/games/super-mario-63" class="text-blue-600 hover:underline"
      >Super Mario 63</a
    >
    <a href="/games/strike-force-heroes" class="text-blue-600 hover:underline"
      >Strike Force Heroes</a
    >
    <a href="/games/madness-project-nexus" class="text-blue-600 hover:underline"
      >Madness: Project Nexus</a
    >
    <a href="/games/gun-mayhem-2" class="text-blue-600 hover:underline"
      >Gun Mayhem 2</a
    >
  </div>

  <div class="games-grid">
    {games.map((g, i) => <Gametile Game={g.Game} Path={g.Path} Image={g.Image} priority={i === 0} />)}
  </div>
</Layout>
