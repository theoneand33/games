---
import Analytics from '@vercel/analytics';
const pageTitle = "Unblocked games";
---
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="stylesheet" href="src/styles/global.css" />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content="Astro" />
        <title>{pageTitle}</title>
        <meta name="description" content="Play the best free unblocked games online. Enjoy a wide variety of games including action, puzzle, strategy, and more - all unblocked and ready to play!" />
        <meta name="keywords" content="unblocked games, free games, online games, action games, puzzle games, strategy games" />
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4683698794241784"
             crossorigin="anonymous"></script>
        <analytics />
        <style>
            @import "tailwindcss";

            .cover-img {
                width: 300px;
                height: 200px;
            }

            .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 10px;
        }

        .game-tile {
            text-align: center;
            text-decoration: none;
            margin: 20px;
            display: inline-block;
        }
        </style>
        <meta name="google-site-verification" content="NBlOMVSv6plhaf7kQsHx4aXHHlFlw1q8N0s44BOlVyk" />
    </head>

    <body>
        <img
            src="/images/games_logo_light.svg"
            alt="light mode version of the GAMEhub logo"
            width="300"
            class="m-5"
        />
        <h1 class="text-xl font-bold mb-4 m-5">Welcome to the best free Unblocked Games website</h1>
        <div class="games-grid">
            <a href="/games/gun-mayhem2" class="game-tile">
                <img
                    src="/images/gm2cover.png"
                    alt="Gun mayhem 2 cover image"
                    class="cover-img rounded-xl hover:scale-105 transition-transform duration-300 hover:shadow-lg active:scale-95 transform"
                />
                <p class="hover:underline decoration-sky-500 decoration-2" >Gun Mayhem 2</p>
            </a>

            <a href="/games/hobo2" class="game-tile">
                <img
                    src="/images/hobo2cover.jpg"
                    alt="Hobo 2 cover image"
                    class="cover-img rounded-xl hover:scale-105 transition-transform duration-300 hover:shadow-lg active:scale-95 transform"
                />
                <p class="hover:underline decoration-sky-500 decoration-2">Hobo 2</p>
            </a>
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4683698794241784"
                 crossorigin="anonymous"></script>
            <!-- Unblocked games ad -->
                        <div class="game-tile">
                            <div class="cover-img rounded-xl hover:scale-105 transition-transform duration-300 hover:shadow-lg active:scale-95 transform flex items-center justify-center bg-gray-100">
                                <ins class="adsbygoogle"
                                     style="display:block"
                                     data-ad-client="ca-pub-4683698794241784"
                                     data-ad-slot="2342476002"
                                     data-ad-format="auto"
                                     data-full-width-responsive="true"></ins>
                                <script>
                                     (adsbygoogle = window.adsbygoogle || []).push({});
                                </script>
                            </div>
                            <p class="hover:underline decoration-sky-500 decoration-2">Advertisement</p>
                        </div>
            <a href="/games/riddle-school2" class="game-tile">
                <img
                    src="/images/Riddle-School-2_logo.png"
                    alt="Riddle School 2 cover image"
                    class="cover-img rounded-xl hover:scale-105 transition-transform duration-300 hover:shadow-lg active:scale-95 transform"
                />
                <p class="hover:underline decoration-sky-500 decoration-2">Riddle School 2</p>
            </a>
            <a href="/games/vex3" class="game-tile">
