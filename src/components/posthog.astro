---
// src/components/posthog.astro
const apiKey = import.meta.env.PUBLIC_POSTHOG_API_KEY;
const apiHost = import.meta.env.PUBLIC_POSTHOG_API_HOST || 'https://us.i.posthog.com';
const isDev = import.meta.env.DEV;

// Only load PostHog if API key is configured and not a placeholder
const shouldLoadPostHog = apiKey &&
  apiKey !== 'your_posthog_api_key_here' &&
  apiKey.startsWith('phc_');
---

{shouldLoadPostHog && (
<script is:inline type="text/javascript" id="posthog-js" define:vars={{apiKey, apiHost}}>
  !(function(t, e) {
    var o, n, p, r;
    e.__SV ||
      ((window.posthog = e),
      (e._i = []),
      (e.init = function(i, s, a) {
        function g(t, e) {
          var o = e.split('.');
          2 == o.length && ((t = t[o[0]]), (e = o[1])),
            (t[e] = function() {
              t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
            });
        }
        ((p = t.createElement('script')).type = 'text/javascript'),
          (p.crossOrigin = 'anonymous'),
          (p.async = true),
          (p.src = s.api_host + '/static/array.js'),
          (r = t.getElementsByTagName('script')[0]).parentNode.insertBefore(p, r);
        var u = e;
        void 0 !== a ? (u = e[a] = []) : (a = 'posthog');
        u.people = u.people || [];
        u.toString = function(t) {
          var e = 'posthog';
          return 'posthog' !== a && (e += '.' + a), t || (e += ' (stub)'), e;
        };
        u.people.toString = function() {
          return u.toString(1) + '.people (stub)';
        };
        o =
          'capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId'.split(
            ' '
          );
        for (n = 0; n < o.length; n++) g(u, o[n]);
        e._i.push([i, s, a]);
      }),
      (e.__SV = 1));
  })(document, window.posthog || []);

  // Initialize PostHog with proper configuration
  try {
    posthog.init(apiKey, {
      api_host: apiHost,
      // Proper configuration options
      loaded: function(posthog) {
        if (isDev) {
          console.log('PostHog loaded successfully');
        }
      },
      // Enable session recording only in production
      session_recording: {
        enabled: !isDev
      },
      // Privacy settings
      respect_dnt: true,
      // Capture page views automatically
      capture_pageview: true,
      // Disable in development for cleaner logs
      debug: isDev,
      // Reduce noise in development
      opt_out_capturing_by_default: isDev
    });
  } catch (error) {
    console.error('Failed to initialize PostHog:', error);
  }
</script>
)}

{!shouldLoadPostHog && (
<!-- PostHog not loaded: API key not configured -->
<script is:inline type="text/javascript" define:vars={{isDev, apiKey}}>
  if (isDev) {
    if (!apiKey) {
      console.log('PostHog not initialized: API key not configured. Set PUBLIC_POSTHOG_API_KEY in your .env file.');
    } else if (apiKey === 'your_posthog_api_key_here') {
      console.log('PostHog not initialized: Please replace placeholder API key with your actual PostHog API key.');
    } else if (!apiKey.startsWith('phc_')) {
      console.log('PostHog not initialized: Invalid API key format. PostHog API keys should start with "phc_".');
    }
  }
</script>
)}
