---
interface Props {
  gamePath: string;
  aspectRatio?: number;
}

const { gamePath, aspectRatio = 4 / 3 } = Astro.props;
---

<div class="text-center">
    <div id="flash-player-wrap" class="flex items-center justify-center p-6 min-h-[calc(100vh-100px)] box-border">
    <div class="flash-loading">Loading game...</div>
  </div>
</div>

<script src="/ruffle/ruffle.js" is:inline></script>
<script data-astro-rerun is:inline>
  (function () {
    var wrap = document.getElementById("flash-player-wrap");
    if (!wrap) return;

    // Cleanup previous instance from view transitions
    if (window.__flashCleanup) {
      window.__flashCleanup();
    }

    var currentPlayer = null;
    var resizeHandler = null;
    var maxAttempts = 50;
    var attempts = 0;
    var GAME_PATH = "{gamePath}";
    var ASPECT_RATIO = /** @type {number} */ ({aspectRatio});

    function showError(msg) {
      wrap.innerHTML =
        '<div class="flash-error">' +
        msg.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;") +
        "</div>";
    }

    function initPlayer(ruffle) {
      wrap.innerHTML = "";
      currentPlayer = ruffle.createPlayer();
      wrap.appendChild(currentPlayer);

      function resize() {
        var vw = window.innerWidth;
        var vh = window.innerHeight;
        var pad = 32;
        var headerOffset = 120;
        var maxW = Math.min(vw - pad * 2, 1040);
        var maxH = vh - headerOffset - pad * 2;
        var w = maxW;
        var h = w / ASPECT_RATIO;
        if (h > maxH) {
          h = maxH;
          w = h * ASPECT_RATIO;
        }
        currentPlayer.style.width = Math.round(w) + "px";
        currentPlayer.style.height = Math.round(h) + "px";
        currentPlayer.style.maxWidth = "100%";
        currentPlayer.style.margin = "0 auto";
      }

      resize();
      resizeHandler = resize;
      window.addEventListener("resize", resize);
      currentPlayer.load(GAME_PATH);
    }

    function ready() {
      try {
        var ruffle =
          typeof window.RufflePlayer !== "undefined" &&
          typeof window.RufflePlayer.newest === "function"
            ? window.RufflePlayer.newest()
            : null;
        if (ruffle) {
          initPlayer(ruffle);
          return;
        }
      } catch (_e) {
        // Ruffle not ready yet
      }
      attempts++;
      if (attempts > maxAttempts) {
        showError(
          "Failed to load Flash player. Please refresh the page.",
        );
        return;
      }
      setTimeout(ready, 200);
    }

    window.__flashCleanup = function () {
      if (resizeHandler) {
        window.removeEventListener("resize", resizeHandler);
        resizeHandler = null;
      }
      if (currentPlayer) {
        try {
          currentPlayer.remove();
        } catch (_e) {
          // ignore
        }
        currentPlayer = null;
      }
    };

    ready();
  })();
</script>
