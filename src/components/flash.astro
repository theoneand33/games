---
interface Props {
  gamePath?: string;
}

const { gamePath } = Astro.props;
---

<span id="flash-config" data-path={gamePath} class="hidden"></span>
<script src="/ruffle/ruffle.js" is:inline></script>
<script data-astro-rerun is:inline>
  (function () {
    var container = document.getElementById('container');
    if (!container) return;

    container.style.display = 'flex';
    container.style.alignItems = 'center';
    container.style.justifyContent = 'center';
    container.style.padding = '24px 16px';
    container.style.minHeight = 'calc(100vh - 100px)';
    container.style.boxSizing = 'border-box';

    container.innerHTML =
      '<div style="background:#f0f0f0;border-radius:8px;color:#666;font-size:1.1rem;padding:40px;">Loading game...</div>';

    var ready = function () {
      var ruffle = window.RufflePlayer && window.RufflePlayer.newest();
      if (!ruffle) {
        setTimeout(ready, 200);
        return;
      }
      container.innerHTML = '';
      var player = ruffle.createPlayer();
      container.appendChild(player);

      var vw = window.innerWidth;
      var vh = window.innerHeight;
      var pad = 32;
      var tabBar = 120;
      var targetRatio = 4 / 3;

      var maxW = Math.min(vw - pad * 2, 1040);
      var maxH = vh - tabBar - pad * 2;

      var w = maxW;
      var h = w / targetRatio;
      if (h > maxH) {
        h = maxH;
        w = h * targetRatio;
      }

      player.style.width = Math.round(w) + 'px';
      player.style.height = Math.round(h) + 'px';
      player.style.maxWidth = '100%';
      player.style.margin = '0 auto';

      var path = document.getElementById('flash-config').getAttribute('data-path');
      player.load(path);
    };
    ready();
  })();
</script>
