---
interface Props {
  gamePath: string;
  aspectRatio?: number;
}

const { gamePath, aspectRatio = 4 / 3 } = Astro.props;
---

<div class="text-center">
    <div id="flash-player-wrap" data-path={gamePath} data-ratio={String(aspectRatio)} class="flex items-center justify-center p-6 min-h-[calc(100vh-100px)] box-border">
    <div class="flash-loading">Loading game...</div>
  </div>
</div>

<script src="/ruffle/ruffle.js" is:inline></script>
<script is:inline>
  (function () {
    var wrap = document.getElementById("flash-player-wrap");
    if (!wrap) return;

    // ── state ──
    var currentPlayer = null;
    var resizeHandler = null;
    var destroyed = false;
    var GAME_PATH = wrap.getAttribute("data-path") || "";
    var ASPECT_RATIO = parseFloat(wrap.getAttribute("data-ratio")) || 4 / 3;

    // ── helpers ──
    function showError(msg) {
      wrap.innerHTML =
        '<div class="flash-error">' +
        msg.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;") +
        "</div>";
    }

    function cleanup() {
      if (destroyed) return;
      destroyed = true;
      if (resizeHandler) {
        window.removeEventListener("resize", resizeHandler);
        resizeHandler = null;
      }
      if (currentPlayer) {
        try { currentPlayer.remove(); } catch (_e) { /* ignore */ }
        currentPlayer = null;
      }
    }

    function initPlayer(ruffle) {
      if (destroyed) return;
      wrap.innerHTML = "";
      currentPlayer = ruffle.createPlayer();
      wrap.appendChild(currentPlayer);

      function resize() {
        var vw = window.innerWidth;
        var vh = window.innerHeight;
        var pad = 32;
        var headerOffset = 120;
        var maxW = Math.min(vw - pad * 2, 1040);
        var maxH = vh - headerOffset - pad * 2;
        var w = maxW;
        var h = w / ASPECT_RATIO;
        if (h > maxH) {
          h = maxH;
          w = h * ASPECT_RATIO;
        }
        currentPlayer.style.width = Math.round(w) + "px";
        currentPlayer.style.height = Math.round(h) + "px";
        currentPlayer.style.maxWidth = "100%";
        currentPlayer.style.margin = "0 auto";
      }

      resize();
      resizeHandler = resize;
      window.addEventListener("resize", resize);

      // load the SWF with error handling
      currentPlayer.load(GAME_PATH).catch(function (err) {
        if (!destroyed) {
          showError("Failed to load game: " + (err.message || "unknown error"));
        }
      });
    }

    // ── Ruffle readiness (polling fallback) ──
    var maxAttempts = 50;
    var attempts = 0;

    function ready() {
      if (destroyed) return;
      try {
        var ruffle =
          typeof window.RufflePlayer !== "undefined" &&
          typeof window.RufflePlayer.newest === "function"
            ? window.RufflePlayer.newest()
            : null;
        if (ruffle && typeof ruffle.createPlayer === "function") {
          initPlayer(ruffle);
          return;
        }
      } catch (_e) {
        // Ruffle not ready yet
      }
      attempts++;
      if (attempts > maxAttempts) {
        showError("Failed to load Flash player. Please refresh the page.");
        return;
      }
      setTimeout(ready, 200);
    }

    ready();

    // ── lifecycle: clean up on view-transition navigation ──
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  })();
</script>
