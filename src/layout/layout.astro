---
import "../styles/styles.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { getGameSEO } from "../data/game-seo";
import { ClientRouter } from "astro:transitions";

interface Props {
  Game: string;
  description?: string;
  image?: string;
  genre?: string;
  year?: string;
  keywords?: string;
}

const { Game } = Astro.props;
const seo = getGameSEO(Game);

const gameTitle = `Play ${Game} Unblocked on Chromebook - No Flash Required (2026)`;
const gameDescription =
  Astro.props.description ||
  seo?.description ||
  `Play ${Game} unblocked on your school Chromebook. No Flash plugin or download needed - runs directly in your browser. Fully working 2026 version of this classic game.`;
const gameImage =
  Astro.props.image || seo?.image || "/images/games_logo_light.svg";
const gameGenre = Astro.props.genre || seo?.genre || "Game";
const gameYear = Astro.props.year || seo?.year || "";
const gameKeywords = `${Astro.props.keywords || seo?.keywords || `${Game.toLowerCase()} unblocked, ${Game.toLowerCase()} online, ${Game.toLowerCase()} working, play ${Game.toLowerCase()}`}, ${Game.toLowerCase()} chromebook, ${Game.toLowerCase()} school, unblocked games chromebook`;
const siteUrl = "https://unblocked-games.vercel.app";
const pageSlug = Game.toLowerCase()
  .replace(/\s+/g, "-")
  .replace(/[^a-z0-9-]/g, "");
const pageUrl = `${siteUrl}/games/${pageSlug}`;
const isFlash = seo?.isFlash ?? false;
const todayDate = "2026-06-10"; // site-wide last updated date
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{gameTitle}</title>
    <meta name="description" content={gameDescription} />
    <meta name="keywords" content={gameKeywords} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />
    {
      isFlash && (
        <link rel="preload" href="/ruffle/ruffle.js" as="script" crossorigin="anonymous" />
      )
    }

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={gameTitle} />
    <meta property="og:description" content={gameDescription} />
    <meta property="og:image" content={`${siteUrl}${gameImage}`} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Superfun Games" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={gameTitle} />
    <meta name="twitter:description" content={gameDescription} />
    <meta name="twitter:image" content={`${siteUrl}${gameImage}`} />

    <!-- JSON-LD Structured Data (BreadcrumbList) -->
    <script
      type="application/ld+json"
      data-seo
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
          { "@type": "ListItem", position: 2, name: "Games", item: siteUrl },
          { "@type": "ListItem", position: 3, name: Game, item: pageUrl },
        ],
      }).replace(/</g, "\\u003c")}
    />
    <!-- JSON-LD Structured Data (VideoGame Schema) -->
    <script
      type="application/ld+json"
      data-seo
      set:html={(() => {
        const data = {
          "@context": "https://schema.org",
          "@type": "VideoGame",
          name: Game,
          description: gameDescription,
          image: `${siteUrl}${gameImage}`,
          url: pageUrl,
          genre: gameGenre,
          gamePlatform: "Web Browser",
          operatingSystem: "All (including Chrome OS / Chromebook)",
          browserRequirements:
            "Works in all modern browsers including Chrome on Chromebook",
          author: {
            "@type": "Organization",
            name: "Superfun Games",
          },
          offers: {
            "@type": "Offer",
            price: "0",
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
          },
          applicationCategory: "GameApplication",
          dateModified: todayDate,
        };
        if (gameYear) data.datePublished = gameYear;
        if (isFlash)
          data.requirements =
            "No Flash plugin needed - runs via Ruffle emulator";
        return JSON.stringify(data).replace(/</g, "\\u003c");
      })()}
    />

    <Analytics />
    <SpeedInsights />
  </head>
  <body>
    <nav class="flex items-center justify-between">
      <a href="/" data-astro-prefetch>
        <img
          src="/images/games_logo_light.svg"
          alt="Superfun Games - Unblocked Games Home"
          width="300"
          class="m-5"
        />
      </a>
      <div class="mr-5 flex gap-4 text-sm">
        <a href="/" class="hover:underline underline-offset-2">Home</a>
        <a href="/dmca" class="hover:underline underline-offset-2">DMCA</a>
      </div>
    </nav>

    <!-- SEO h1 (slim — keeps game visible without scrolling) -->
    <div style="padding: 0.5rem 1.5rem 0; max-width: 1200px; margin: 0 auto;">
      <h1 style="font-size: 1.25rem; font-weight: 700;">
        Play {Game} Unblocked on Chromebook
      </h1>
    </div>

    <main>
      <slot />
    </main>

    <!-- SEO description + badges (below the game — still indexed by search engines) -->
    <div
      class="game-seo-content"
      style="padding: 0.5rem 1.5rem; max-width: 1200px; margin: 0 auto;"
    >
      <p style="font-size: 0.875rem; color: #555; margin-bottom: 0.25rem;">
        {gameDescription.substring(0, 200)}
        {gameDescription.length > 200 ? "..." : ""}
      </p>
      {
        isFlash && (
          <p style="font-size: 0.75rem; color: #888; font-weight: 500;">
            ✓ No Flash plugin required — works on school Chromebooks via Ruffle
            emulator
          </p>
        )
      }
      {
        !isFlash && (
          <p style="font-size: 0.75rem; color: #888; font-weight: 500;">
            ✓ Works on school Chromebooks — no downloads needed
          </p>
        )
      }
    </div>

    <!-- Internal cross-linking: More Games -->
    <nav
      class="more-games"
      style="padding: 1rem 1.5rem; max-width: 1200px; margin: 0 auto; border-top: 1px solid #e5e7eb; margin-top: 1rem;"
    >
      <p
        style="font-size: 0.875rem; font-weight: 600; margin-bottom: 0.5rem; color: #374151;"
      >
        More Unblocked Games
      </p>
      <div
        style="display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.8rem;"
      >
        <a href="/games/happywheels" class="text-blue-600 hover:underline"
          >Happy Wheels</a
        >
        <a href="/games/gun-mayhem2" class="text-blue-600 hover:underline"
          >Gun Mayhem 2</a
        >
        <a
          href="/games/madness-project-nexus"
          class="text-blue-600 hover:underline">Madness Project Nexus</a
        >
        <a href="/games/hobo2" class="text-blue-600 hover:underline">Hobo 2</a>
        <a href="/games/vex3" class="text-blue-600 hover:underline">Vex 3</a>
        <a
          href="/games/fireboy-and-watergirl"
          class="text-blue-600 hover:underline">Fireboy and Watergirl</a
        >
        <a
          href="/games/strike-force-heroes"
          class="text-blue-600 hover:underline">Strike Force Heroes</a
        >
        <a href="/games/super-mario-63" class="text-blue-600 hover:underline"
          >Super Mario 63</a
        >
        <a href="/games/bloonstd5" class="text-blue-600 hover:underline"
          >Bloons TD 5</a
        >
      </div>
    </nav>

    <footer>
      <p>
        All games sourced from <a
          class="hover:underline underline-offset-2 text-blue-600"
          href="https://archive.org">Internet Archive</a
        >
      </p>
      <div style="font-size: 13px;" class="flex gap-3">
        <a class="hover:underline underline-offset-2" href="/dmca">DMCA</a>
      </div>
    </footer>
    <ClientRouter />
  </body>
</html>
