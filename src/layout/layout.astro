---
interface Props {
  Game: string; // Define that Layout expects a 'Game' prop, which is a string
}

const { Game } = Astro.props; // Destructure Game from Astro.props
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Play ${Game} unblocked online.`} />
    <title>{Game}</title>
    <script defer src="/_vercel/insights/script.js"></script>
  </head>
  <body>
    <nav>
      <a href="/">
        <img
          src="/images/games_logo_light.svg"
          alt="light mode version of the GAMEhub logo"
          width="300"
          class="m-5"
        />
      </a>
    </nav>
    <main><slot /></main>
    <footer>
      <p>
        All games sourced from <a
          class="hover:underline underline-offset-2"
          href="https://archive.org">Internet Archive</a
        >
      </p>
      <div style="font-size: 13px;">
        <a class="hover:underline underline-offset-2" href="/dmca">DMCA</a>
      </div>
    </footer>
  </body>
</html>
