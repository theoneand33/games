---
import "../styles/styles.css";
import Analytics from "@vercel/analytics/astro";
interface Props {
  Game: string;
}

const { Game } = Astro.props;
import { OpenPanelComponent } from "@openpanel/astro";
import { ClientRouter } from "astro:transitions";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Play ${Game} unblocked online.`} />
    <title>{Game}</title>
    <Analytics />
    <ClientRouter />
  </head>
  <body>
    <nav>
      <a href="/" data-astro-prefetch>
        <img
          src="/images/games_logo_light.svg"
          alt="light mode version of the GAMEhub logo"
          width="300"
          class="m-5"
        />
      </a>
    </nav>
    <main>
      <slot />
      <OpenPanelComponent
        clientId="a680ca86-3d81-4e1b-a83d-96f72967c2d1"
        trackScreenViews={true}
        trackAttributes={true}
        trackOutgoingLinks={true}
      />
    </main>
    <footer>
      <p>
        All games sourced from <a
          class="hover:underline underline-offset-2"
          href="https://archive.org">Internet Archive</a
        >
      </p>
      <div style="font-size: 13px;">
        <a class="hover:underline underline-offset-2" href="/dmca">DMCA</a>
      </div>
    </footer>
  </body>
</html>
