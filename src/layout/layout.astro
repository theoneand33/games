---
import "../styles/styles.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  Game?: string;
  pageTitle?: string;
}

const { Game, pageTitle } = Astro.props;
const title = Game ?? pageTitle ?? "Unblocked Games";
const description = Game
  ? `Play ${Game} unblocked online.`
  : "Play the best free games online. Enjoy a wide variety of games including action, puzzle, strategy, and more!";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="unblocked games, free games, online games, action games, puzzle games, strategy games, vercel unblocked games, unblocked games vercel, unblocked games vercel app, video games, online video games, free video games, unblocked video games, action video games, puzzle video games, strategy video games, action video games online, puzzle video games online, strategy video games online, action games online, puzzle games online, strategy games online"
    />
    <meta
      name="google-site-verification"
      content="NBlOMVSv6plhaf7kQsHx4aXHHlFlw1q8N0s44BOlVyk"
    />
    <title>{title}</title>
    <ClientRouter />
    <Analytics />
    <SpeedInsights />
  </head>
  <body>
    <nav class="flex items-center justify-between">
      <a href="/" data-astro-prefetch>
        <img
          src="/images/games_logo_light.svg"
          alt="GAMEhub logo"
          width="300"
          class="m-5"
        />
      </a>
      <div class="mr-5 flex gap-4 text-sm">
        <a href="/" class="hover:underline underline-offset-2">Home</a>
        <a href="/dmca" class="hover:underline underline-offset-2">DMCA</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      {Game && (
        <p>If this page is blank try reloading it</p>
      )}
      <p>
        All games sourced from <a
          class="hover:underline underline-offset-2 text-blue-700"
          href="https://archive.org">Internet Archive</a
        >
      </p>
      <div style="font-size: 13px;" class="flex gap-3">
        <a class="hover:underline underline-offset-2" href="/dmca">DMCA</a>
      </div>
    </footer>
  </body>
</html>
