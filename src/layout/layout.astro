---
import "../styles/styles.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { getGameSEO, slugify } from "../data/game-seo";
import { slugToGame } from "../data/game-slugs";

// build reverse map: game name → actual page slug
const gameToSlug: Record<string, string> = {};
for (const [slug, name] of Object.entries(slugToGame)) {
  gameToSlug[name] = slug;
}

interface Props {
  Game?: string;
  pageTitle?: string;
  description?: string;
  image?: string;
  genre?: string;
  year?: string;
  keywords?: string;
  isHome?: boolean;
}

const { Game, pageTitle, isHome } = Astro.props;
const siteUrl = "https://unblocked-games.vercel.app";

// SEO data
const seo = Game ? getGameSEO(Game) : undefined;
const isFlash = seo?.isFlash ?? false;
const todayDate = new Date().toISOString().split('T')[0];

// Title
const gameTitle = Game
  ? `Play ${Game} Unblocked on Chromebook - No Flash Required (2026)`
  : pageTitle || "Superfun Games - Unblocked Games for School Chromebook";

// Description
const homeDescription = "Play the best free unblocked games online at school on your Chromebook - Happy Wheels, Gun Mayhem 2, Plants vs Zombies, Strike Force Heroes, and more classic Flash games. No Flash plugin or download required, all games work directly in your browser. Updated and working in 2026.";

const gameDescription = isHome
  ? homeDescription
  : Astro.props.description
    || seo?.description
    || `Play ${Game} unblocked on your school Chromebook. No Flash plugin or download needed - runs directly in your browser. Fully working 2026 version of this classic game.`;

// Image & other SEO fields
const gameImage = isHome
  ? "/images/games_logo_light.svg"
  : (Astro.props.image || seo?.image || "/images/games_logo_light.svg");

const gameGenre = Astro.props.genre || seo?.genre || "Game";
const gameYear = Astro.props.year || seo?.year || "";

// Keywords
const homeKeywords = "unblocked games, unblocked games for school chromebook, classic flash games, browser games";

const gameKeywords = isHome
  ? homeKeywords
  : `${Game?.toLowerCase()} unblocked, ${Game?.toLowerCase()} online, unblocked games chromebook`;

// URL — use actual page slug from slugToGame, fallback to slugify
const pageSlug = Game ? (gameToSlug[Game] || slugify(Game)) : "";
const pageUrl = Game ? `${siteUrl}/games/${pageSlug}` : siteUrl;

// More Games cross-linking — curated list of popular games
const moreGames = [
  "Happy Wheels",
  "Gun Mayhem 2",
  "Madness: Project Nexus",
  "Hobo 2",
  "Vex 3",
  "Fireboy and Watergirl",
  "Strike Force Heroes",
  "Super Mario 63",
  "Bloons TD 5",
].filter(name => name !== Game); // exclude current game
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{gameTitle}</title>
    <meta name="description" content={gameDescription} />
    <meta name="keywords" content={gameKeywords} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />

    {
      isHome && (
        <meta name="google-site-verification" content="NBlOMVSv6plhaf7kQsHx4aXHHlFlw1q8N0s44BOlVyk" />
      )
    }

    {
      isFlash && (
        <link rel="preload" href="/ruffle/ruffle.js" as="script" crossorigin="anonymous" />
      )
    }

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={gameTitle} />
    <meta property="og:description" content={gameDescription} />
    <meta property="og:image" content={`${siteUrl}${gameImage}`} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Superfun Games" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={gameTitle} />
    <meta name="twitter:description" content={gameDescription} />
    <meta name="twitter:image" content={`${siteUrl}${gameImage}`} />

    {
      Game && !isHome ? (
        <>
          <!-- JSON-LD BreadcrumbList -->
          <script is:inline
            type="application/ld+json"
            set:html={JSON.stringify({
              "@context": "https://schema.org",
              "@type": "BreadcrumbList",
              itemListElement: [
                { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
                { "@type": "ListItem", position: 2, name: "Games", item: siteUrl },
                { "@type": "ListItem", position: 3, name: Game, item: pageUrl },
              ],
            }).replace(/</g, "\\u003c")}
          />
          <!-- JSON-LD VideoGame -->
          <script is:inline
            type="application/ld+json"
            set:html={(() => {
              const data = {
                "@context": "https://schema.org",
                "@type": "VideoGame",
                name: Game,
                description: gameDescription,
                image: `${siteUrl}${gameImage}`,
                url: pageUrl,
                genre: gameGenre,
                gamePlatform: "Web Browser",
                operatingSystem: "All (including Chrome OS / Chromebook)",
                browserRequirements:
                  "Works in all modern browsers including Chrome on Chromebook",
                author: { "@type": "Organization", name: "Superfun Games" },
                offers: {
                  "@type": "Offer",
                  price: "0",
                  priceCurrency: "USD",
                  availability: "https://schema.org/InStock",
                },
                applicationCategory: "GameApplication",
                dateModified: todayDate,
                ...(gameYear ? { datePublished: gameYear } : {}),
                ...(isFlash
                  ? { requirements: "No Flash plugin needed - runs via Ruffle emulator" }
                  : {}),
              };
              return JSON.stringify(data).replace(/</g, "\\u003c");
            })()}
          />
        </>
      ) : null
    }

    {
      isHome ? (
        <>
          <!-- JSON-LD WebSite -->
          <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "Superfun Games",
            "url": siteUrl,
            "description": homeDescription,
            "potentialAction": {
              "@type": "SearchAction",
              "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/?search={search_term_string}` },
              "query-input": "required name=search_term_string"
            }
          }).replace(/</g, "\\u003c")} />
          <!-- JSON-LD CollectionPage -->
          <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "CollectionPage",
            "name": "Unblocked Games Collection",
            "description": "A curated collection of classic Flash games and browser games that work without Flash Player. All games run directly in your browser using modern emulation.",
            "url": siteUrl,
            "about": { "@type": "Thing", "name": "Classic Browser Games" }
          }).replace(/</g, "\\u003c")} />
          <!-- JSON-LD Organization -->
          <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "Superfun Games",
            "url": siteUrl,
            "description": homeDescription,
            "foundingDate": "2024",
            "sameAs": ["https://github.com/noahgsolomon/unblocked-games"]
          }).replace(/</g, "\\u003c")} />
        </>
      ) : null
    }

    <Analytics />
    <SpeedInsights />
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-component-ui.js" type="module" is:inline></script>
  </head>
  <body>
    <nav class="flex items-center justify-between">
      <a href="/" data-astro-prefetch>
        <img
          src="/images/games_logo_light.svg"
          alt="Superfun Games - Unblocked Games Home"
          width="300"
          class="m-5"
        />
      </a>
      <div class="mr-5 flex gap-4 text-sm items-center">
        <a href="/" class="hover:text-black text-gray-800 transition-colors">Home</a>
        <a href="/dmca" class="hover:text-black text-gray-800 transition-colors">DMCA</a>
        <pagefind-searchbox></pagefind-searchbox>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    {Game && !isHome && (
      <div class="mx-auto max-w-[1200px] px-6 pt-2">
        <h1 data-pagefind-body class="text-xl font-bold">
          Play {Game} Unblocked on Chromebook
        </h1>

        <!-- SEO description + badges (line-clamp for clean truncation) -->
        <div class="py-2">
          <p class="text-sm text-gray-500 mb-1 line-clamp-3">
            {gameDescription}
          </p>
          <p class="text-xs text-gray-400 font-medium">
            ✓ {isFlash
              ? "No Flash plugin required — works on school Chromebooks via Ruffle emulator"
              : "Works on school Chromebooks — no downloads needed"}
          </p>
        </div>

        <!-- More Games cross-linking (dynamically generated) -->
        <nav class="border-t border-gray-200 mt-4 py-4">
          <p class="text-sm font-semibold mb-2 text-gray-700">More Unblocked Games</p>
          <div class="flex flex-wrap gap-2 text-xs">
            {moreGames.map(otherGame => (
              <a href={`/games/${gameToSlug[otherGame] || slugify(otherGame)}`} class="text-blue-600 hover:underline">{otherGame}</a>
            ))}
          </div>
        </nav>
      </div>
    )}

    <footer>
      <p class="ml-6 mb-4">
        All games sourced from <a
          class="hover:underline underline-offset-2 text-blue-600"
          href="https://archive.org">Internet Archive</a
        >
      </p>
    </footer>
  </body>
</html>
