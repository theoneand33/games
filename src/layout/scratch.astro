---
import { getGameSEO } from "../data/game-seo";

interface Props {
  Game: string;
}

const { Game } = Astro.props;
const seo = getGameSEO(Game);

const gameDescription = seo?.description || `Play ${Game} unblocked on your school Chromebook. No Flash or download needed.`;
const siteUrl = "https://unblocked-games.vercel.app";
const pageUrl = `${siteUrl}/games/${Game.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "")}`;
const gameImage = seo?.image || "/images/games_logo_light.svg";
const gameTitle = `Play ${Game} Unblocked on Chromebook - No Flash Required (2026)`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary SEO -->
    <title>{gameTitle}</title>
    <meta name="description" content={gameDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={gameTitle} />
    <meta property="og:description" content={gameDescription} />
    <meta property="og:image" content={`${siteUrl}${gameImage}`} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Superfun Games" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={gameTitle} />
    <meta name="twitter:description" content={gameDescription} />
    <meta name="twitter:image" content={`${siteUrl}${gameImage}`} />

    <script defer src="/_vercel/insights/script.js"></script>
    <style>
      body {
        margin: 0;
        overflow: hidden;
      }
      iframe {
        width: 98vw;
        height: 96vh;
        border: none;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">
        <img
          src="/images/games_logo_light.svg"
          alt="Superfun Games - Unblocked Games Home"
          width="300"
          class="m-5"
        />
      </a>
    </nav>
    <nav>
      <slot />
    </nav>
    <footer>
      <p>
        All games sourced from <a
          class="hover:underline underline-offset-2"
          href="https://archive.org">Internet Archive</a
        >
      </p>
      <div style="font-size: 13px;">
        <a class="hover:underline underline-offset-2" href="/dmca">DMCA</a>
      </div>
    </footer>
  </body>
</html>
